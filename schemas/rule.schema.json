{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "E.coil rule registry entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "priority_class",
    "rule_type",
    "source",
    "species_scope",
    "participants",
    "conditions",
    "effects",
    "constraints",
    "confidence"
  ],
  "properties": {
    "rule_id": {"type": "string", "minLength": 1},
    "priority_class": {"type": "string", "enum": ["custom", "native", "basal"]},
    "rule_type": {
      "type": "string",
      "enum": [
        "transcription_regulation",
        "translation_effect",
        "catalysis",
        "transport",
        "binding",
        "ppi",
        "complex_assembly",
        "complex_disassembly",
        "inhibition",
        "activation",
        "degradation",
        "mutation_effect",
        "environment_shift",
        "abundance_decay"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["database"],
      "properties": {
        "database": {"type": "string"},
        "accession": {"type": "string"},
        "evidence": {"type": "string"}
      }
    },
    "species_scope": {"type": "string"},
    "participants": {"type": "object", "additionalProperties": true},
    "conditions": {"type": "object", "additionalProperties": true},
    "effects": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": true}
    },
    "constraints": {"type": "object", "additionalProperties": true},
    "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
    "notes": {"type": "string"}
  }
}
